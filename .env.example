# Copy to .env.local for local experiments. .env.local is ignored by git.
# Keep this file free of private paths and credentials.

# Common
# HF_HOME=/path/to/huggingface/cache
# DATA_ROOT=/path/to/datasets
# OUTPUT_ROOT=./runs
# MODEL_ROOT=./checkpoints
# PYTHON_BIN=python
# DRY_RUN=false

# FLUX.2
# FLUX2_SRC=/path/to/flux2/source
# FLUX2_MODEL_PATH=/path/to/flux-2-klein-base-4b.safetensors
# FLUX2_AE_MODEL_PATH=/path/to/ae.safetensors
# FLUX2_QWEN3_MODEL_SPEC=Qwen/Qwen3-4B

# OmniGen2
# OMNIGEN2_SRC=/path/to/OmniGen2/source
# OMNIGEN2_MODEL_PATH=/path/to/OmniGen2/model
# QWEN_MODEL_PATH=/path/to/Qwen2.5-VL-3B-Instruct
# QWEN_CACHE_DIR=/path/to/text/cache # optional

# Evaluation
# CKPT_PATH=/path/to/checkpoint.pt
# DATASET_STATS_PATH=/path/to/dataset_stats.json
# LOCAL_CKPT_ROOT=/optional/local/checkpoint/cache # optional, usually not needed.
# LIBERO_WORKER_ENV_SOURCE=/path/to/imagewam/.venv/bin/activate
